      "text": "Offer receipt",
      "order": 0,
      "metadata": {}
    },
    {
      "block_id": "block_0001",
      "block_type": "paragraph",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "The method and location of bid receipt must be specified in the solicitation of offers.",
      "order": 1,
      "metadata": {}
    },
    {
      "block_id": "block_0002",
      "block_type": "paragraph",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "Here are the acceptable methods for offer submission and their conditions:",
      "order": 2,
      "metadata": {}
    },
    {
      "block_id": "block_0003",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "In writing and submitted to the specified receiving unit: applicable for all ($) dollar values",
      "order": 3,
      "metadata": {}
    },
    {
      "block_id": "block_0004",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "In writing and submitted directly to the buyer: for offers below $25,000 for goods and $40,000 for construction and services, including all applicable taxes",
      "order": 4,
      "metadata": {}
    },
    {
      "block_id": "block_0005",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "Verbal submission by telephone:",
      "order": 5,
      "metadata": {}
    },
    {
      "block_id": "block_0006",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "for offers below $25,000 for goods and $40,000 for construction and services, including all applicable taxes",
      "order": 6,
      "metadata": {}
    },
    {
      "block_id": "block_0007",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "for any ($) dollar value in cases of documented extreme urgency, the director's approval is mandatory",
      "order": 7,
      "metadata": {}
    },
    {
      "block_id": "block_0008",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "On electronic media (e.g., DVD s, USB keys, CD s) and submitted to the specified receiving unit",
      "order": 8,
      "metadata": {}
    },
    {
      "block_id": "block_0009",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "By facsimile",
      "order": 9,
      "metadata": {}
    },
    {
      "block_id": "block_0010",
      "block_type": "list_item",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "Canada Post Corporation’s Connect service",
      "order": 10,
      "metadata": {}
    },
    {
      "block_id": "block_0011",
      "block_type": "paragraph",
      "heading": "Offer receipt",
      "heading_path": [
        "Offer receipt"
      ],
      "text": "In situations where a particular method of response is deemed not acceptable, you must clearly indicate this in the solicitation document and in the Notice of Proposed Procurement (NPP).",
      "order": 11,
      "metadata": {}
    }
  ],
