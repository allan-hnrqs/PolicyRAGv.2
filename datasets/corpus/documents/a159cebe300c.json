  "structure_blocks": [
    {
      "block_id": "block_0000",
      "block_type": "heading",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "Interim Policy on Reciprocal Procurement",
      "order": 0,
      "metadata": {}
    },
    {
      "block_id": "block_0001",
      "block_type": "paragraph",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "Canada implemented the Interim Policy on Reciprocal Procurement to protect and support Canadian workers and businesses and to develop mutually beneficial and resilient supply chains.",
      "order": 1,
      "metadata": {}
    },
    {
      "block_id": "block_0002",
      "block_type": "paragraph",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "Under the Policy, Canadian businesses have default access to all federal procurement opportunities. Foreign businesses are only eligible for procurements that are subject to a trade agreement between Canada and the supplier’s jurisdiction.",
      "order": 2,
      "metadata": {}
    },
    {
      "block_id": "block_0003",
      "block_type": "paragraph",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "The Policy applies to new procurements (excluding defence procurements) and renewals of supply arrangements or standing offers, but not existing contracts.",
      "order": 3,
      "metadata": {}
    },
    {
      "block_id": "block_0004",
      "block_type": "paragraph",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "The Policy came into effect on July 14, 2025.",
      "order": 4,
      "metadata": {}
    },
    {
      "block_id": "block_0005",
      "block_type": "paragraph",
      "heading": "Interim Policy on Reciprocal Procurement",
      "heading_path": [
        "Interim Policy on Reciprocal Procurement"
      ],
      "text": "For more information on the steps to apply the Policy, see the Buyer's Guide, Interim Policy on Reciprocal Procurement .",
      "order": 5,
      "metadata": {}
    }
  ],
  "metadata": {},
  "raw_text": "Interim Policy on Reciprocal Procurement\n\nCanada implemented the Interim Policy on Reciprocal Procurement to protect and support Canadian workers and businesses and to develop mutually beneficial and resilient supply chains.\n\nUnder the Policy, Canadian businesses have default access to all federal procurement opportunities. Foreign businesses are only eligible for procurements that are subject to a trade agreement between Canada and the supplier’s jurisdiction.\n\nThe Policy applies to new procurements (excluding defence procurements) and renewals of supply arrangements or standing offers, but not existing contracts.\n\nThe Policy came into effect on July 14, 2025.\n\nFor more information on the steps to apply the Policy, see the Buyer's Guide, Interim Policy on Reciprocal Procurement .",
  "markdown_text": "Interim Policy on Reciprocal Procurement\n\nCanada implemented the Interim Policy on Reciprocal Procurement to protect and support Canadian workers and businesses and to develop mutually beneficial and resilient supply chains.\n\nUnder the Policy, Canadian businesses have default access to all federal procurement opportunities. Foreign businesses are only eligible for procurements that are subject to a trade agreement between Canada and the supplier’s jurisdiction.\n\nThe Policy applies to new procurements (excluding defence procurements) and renewals of supply arrangements or standing offers, but not existing contracts.\n\nThe Policy came into effect on July 14, 2025.\n\nFor more information on the steps to apply the Policy, see the Buyer's Guide, Interim Policy on Reciprocal Procurement .",
  "provenance_paths": {}
