      ],
      "text": "amendments to any of the above",
      "order": 14,
      "metadata": {}
    },
    {
      "block_id": "block_0015",
      "block_type": "heading",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "Advance, milestone and progress payments",
      "order": 15,
      "metadata": {}
    },
    {
      "block_id": "block_0016",
      "block_type": "paragraph",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "The authority for certification of advance, milestone and progress payment claims form PWGSC-TPSGC 1111 (Claim for Progress Payment) is a prerequisite for client certification pursuant to section 34 of the Financial Administration Act is as follows:",
      "order": 16,
      "metadata": {}
    },
    {
      "block_id": "block_0017",
      "block_type": "list_item",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "Unlimited certification authority applies for incumbents of positions listed in the Table of equivalent positions within AP , with the exception of intern officers/trainees, senior purchasing assistants and procurement assistants.",
      "order": 17,
      "metadata": {}
    },
    {
      "block_id": "block_0018",
      "block_type": "paragraph",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "Senior purchasing assistants have certification authority as follows:",
      "order": 18,
      "metadata": {}
    },
    {
      "block_id": "block_0019",
      "block_type": "list_item",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "for contracts beyond their approval authority: claims up to $40,000 with the exception of a final claim or of a release of a holdback",
      "order": 19,
      "metadata": {}
    },
    {
      "block_id": "block_0020",
      "block_type": "list_item",
      "heading": "Advance, milestone and progress payments",
      "heading_path": [
        "Additional signing authorities",
        "Advance, milestone and progress payments"
      ],
      "text": "for contracts within approval authority: all claims",
      "order": 20,
      "metadata": {}
    },
    {
      "block_id": "block_0021",
      "block_type": "heading",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "Settlement and release documents",
      "order": 21,
      "metadata": {}
    },
    {
      "block_id": "block_0022",
      "block_type": "paragraph",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "The authority to sign release and settlement documents (form PWGSC-TPSGC 9223-2 , for terminations on behalf of the Minister of PSPC is delegated as follows",
      "order": 22,
      "metadata": {}
    },
    {
      "block_id": "block_0023",
      "block_type": "list_item",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "arising from a termination for convenience:",
      "order": 23,
      "metadata": {}
    },
    {
      "block_id": "block_0024",
      "block_type": "list_item",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "DG , Procurement Support Services Sector, AP",
      "order": 24,
      "metadata": {}
    },
    {
      "block_id": "block_0025",
      "block_type": "list_item",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "Director, Centralized Services Directorate, AP",
      "order": 25,
      "metadata": {}
    },
    {
      "block_id": "block_0026",
      "block_type": "list_item",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "for other than a termination of convenience, PSPC buyers must consult with Finance Branch to determine the appropriate approval authority level",
      "order": 26,
      "metadata": {}
    },
    {
      "block_id": "block_0027",
      "block_type": "paragraph",
      "heading": "Settlement and release documents",
      "heading_path": [
        "Additional signing authorities",
        "Settlement and release documents"
      ],
      "text": "For assistance on terminations for convenience, consult the Specialized Services for Procurement Division (SSPD) .",
      "order": 27,
      "metadata": {}
    },
    {
      "block_id": "block_0028",
      "block_type": "heading",
      "heading": "Contract security",
      "heading_path": [
        "Additional signing authorities",
        "Contract security"
      ],
      "text": "Contract security",
      "order": 28,
      "metadata": {}
    },
    {
      "block_id": "block_0029",
      "block_type": "paragraph",
      "heading": "Contract security",
      "heading_path": [
        "Additional signing authorities",
        "Contract security"
      ],
      "text": "The Contract Security Program has the authority to provide instructions to contractors concerning compliance with contract security requirements.",
      "order": 29,
      "metadata": {}
    }
