      "metadata": {}
    },
    {
      "block_id": "block_0001",
      "block_type": "paragraph",
      "heading": "Considerations when making amendments",
      "heading_path": [
        "Buyer's Guide Modify a contract - Considerations when making amendments",
        "Considerations when making amendments"
      ],
      "text": "Contract amendments are used to formally delete, modify or introduce new conditions to the original contract. The need for an amendment may arise from ongoing negotiations or to deal with an unforeseen circumstances. Amendments must always consider Canada's best interests and require the agreement of both parties to the contract. Where the vendor is subject to a relevant Vendor Performance Corrective Measure Policy (VPCMP), the length of the contract cannot be extended either by an amendment or through the exercise of an option unless:",
      "order": 1,
      "metadata": {}
    },
    {
      "block_id": "block_0002",
      "block_type": "list_item",
      "heading": "Considerations when making amendments",
      "heading_path": [
        "Buyer's Guide Modify a contract - Considerations when making amendments",
        "Considerations when making amendments"
      ],
      "text": "there is insufficient time to recompete",
      "order": 2,
      "metadata": {}
    },
    {
      "block_id": "block_0003",
      "block_type": "list_item",
      "heading": "Considerations when making amendments",
      "heading_path": [
        "Buyer's Guide Modify a contract - Considerations when making amendments",
        "Considerations when making amendments"
      ],
      "text": "there are other exceptional circumstances",
      "order": 3,
      "metadata": {}
    },
    {
      "block_id": "block_0004",
      "block_type": "paragraph",
      "heading": "Considerations when making amendments",
      "heading_path": [
        "Buyer's Guide Modify a contract - Considerations when making amendments",
        "Considerations when making amendments"
      ],
      "text": "Both will require Assistant Deputy Minister (ADM) approval.",
      "order": 4,
      "metadata": {}
    }
