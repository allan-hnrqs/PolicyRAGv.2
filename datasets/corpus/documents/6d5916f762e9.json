    {
      "block_id": "block_0000",
      "block_type": "heading",
      "heading": "When to negotiate",
      "heading_path": [
        "When to negotiate"
      ],
      "text": "When to negotiate",
      "order": 0,
      "metadata": {}
    },
    {
      "block_id": "block_0001",
      "block_type": "paragraph",
      "heading": "When to negotiate",
      "heading_path": [
        "When to negotiate"
      ],
      "text": "When two or more compliant offers are received following a solicitation of offers and no offer represents fair value, you should examine the solicitation document to determine possible causes. You may then consider either negotiating with all compliant offerors or cancelling and reissuing the solicitation. If urgency is a major factor, it may be possible to use the results of the original solicitation of offers as a basis for negotiations.",
      "order": 1,
      "metadata": {}
    },
    {
      "block_id": "block_0002",
      "block_type": "paragraph",
      "heading": "When to negotiate",
      "heading_path": [
        "When to negotiate"
      ],
      "text": "For procurements subject to the trade agreements, you must conduct negotiations in accordance with the conditions of these agreements. For example see:",
      "order": 2,
      "metadata": {}
    },
    {
      "block_id": "block_0003",
