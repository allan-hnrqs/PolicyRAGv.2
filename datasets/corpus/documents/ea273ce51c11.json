      "heading": "One responsive offer",
      "heading_path": [
        "Special considerations",
        "One responsive offer"
      ],
      "text": "When only one responsive offer is received in response to a competitive solicitation, you must ensure that Canada is obtaining fair value by following the guidelines below.",
      "order": 3,
      "metadata": {}
    },
    {
      "block_id": "block_0004",
      "block_type": "heading",
      "heading": "Offer is greater than $7,500,000",
      "heading_path": [
