      "block_type": "paragraph",
      "heading": "Offer is less than or equal to $7,500,000",
      "heading_path": [
        "Special considerations",
        "One responsive offer",
        "Offer is less than or equal to $7,500,000"
      ],
      "text": "You should consider using the services of a cost analyst to determine if further analysis is required as specified by the mandatory conditions set out in the Guideline on the Use of Cost and Price Analysis Services (accessible only on the Government of Canada network).",
      "order": 8,
      "metadata": {}
